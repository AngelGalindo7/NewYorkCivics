# ─────────────────────────────────────────────────────────────────────────────
# .env.example — config-driven secrets & flags (Rule 6: model names behind config)
#
# Copy to .env and fill in. NEVER commit .env — it holds live secrets.
# .env is git-ignored; this template is the committed reference.
# ─────────────────────────────────────────────────────────────────────────────

# ── Models (Rule 6: swap LLMs without code changes) ──────────────────────────
# Default extractor: Gemini Flash, cheapest vision-capable model.
EXTRACT_MODEL=gemini-2.5-flash
# Cross-family judge vs the Gemini extractor (Rule 12, anti self-preference).
JUDGE_MODEL=claude-haiku-4-5

# ── LLM provider API keys ────────────────────────────────────────────────────
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                 # optional — only if using an OpenAI alt judge

# ── Storage (Postgres + PostGIS) ─────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/nyc_civic

# ── Socrata / SODA (HPD, DOB structured feeds) ───────────────────────────────
# Free app token → ~1000 req/hr. Get one at the NYC Open Data developer portal.
SOCRATA_APP_TOKEN=

# ── GeoSupport (official NYC geocoder → BBL directly) ────────────────────────
# Requires the GeoSupport binaries installed locally + these env vars set.
# NOT Google/Mapbox. See docs/GLOSSARY.md (GeoSupport) for setup caveats.
GEOSUPPORT_GEOFILES=
GEOSUPPORT_GS_LIBRARY_PATH=

# ── Delivery ─────────────────────────────────────────────────────────────────
# Choose provider — one of: ses | postmark | resend | mailchimp.
# Only `resend` is implemented for v1; leave unset to write digests to the file sink.
# A digest is never sent until a human has cleared its review queue.
EMAIL_PROVIDER=
# Verified sender address the provider sends from (required when EMAIL_PROVIDER=resend).
EMAIL_FROM=
# Resend API key (required when EMAIL_PROVIDER=resend); never logged.
RESEND_API_KEY=

# ── Dev overrides (NEVER set to true in production) ──────────────────────────
# Bypass the Rule 9 human-review-then-send gate for local dev / CI runs.
# The data is factually correct (structured public sources); this only skips
# the queue-clearing step so the full digest pipeline can be exercised before
# an organizer has formally validated the displacement signal buildings.
# Rationale: the pipeline's cross-feed BBL correlation is verifiable from public
# sources (HPD + DOB + ZAP) — the human gate guards *delivery*, not data truth.
BYPASS_HUMAN_REVIEW=false

# ── Legistar (NYC Council — OPTIONAL) ────────────────────────────────────────
# The webapi.legistar.com read API now returns 403 to keyless callers, and there is no
# self-serve token portal (a key comes only from Granicus, the platform vendor). The
# connector falls back to scraping the public web calendar, so leave this blank for normal
# use; set it only if you obtain a vendor key.
LEGISTAR_TOKEN=

# ── Airtable (CB11 meeting calendar) ─────────────────────────────────────────
# CB11 (Manhattan CB 11) posts its meeting calendar exclusively in a private
# Airtable base. Obtain a Personal Access Token at airtable.com/create/tokens
# with `data.records:read` scope on the CB11 base. Leave blank to use the
# committed fixture (ingest/tests/fixtures/cb11_meetings_airtable.json).
AIRTABLE_TOKEN=

# ── Langfuse (free Hobby cloud tracing — eval/production traces) ─────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
